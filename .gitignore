# Prerequisites
*.d

# Compiled Object files
*.slo
*.lo
*.o
*.obj
*.iobj
*.ipdb
*.ilk

# ...but keep 3D mesh assets (Wavefront .obj), which all live under PEEL/Media/.
# The blanket *.obj rule above still ignores compiler .obj files in the build dirs.
!PEEL/Media/**/*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
# NOTE: this repo intentionally commits DLL (and EXE) binaries so users can download
# the repo and run precompiled plugins immediately, without building everything.
# So *.dll is deliberately NOT ignored.
# *.dll

# Compiled Static libraries
*.lai
*.la
*.a
#*.lib

# Executables
# *.exe   -- intentionally NOT ignored; see the DLL note above (precompiled binaries are committed)
*.out
*.app

*.ncb
*.suo
*.bsc
*.exp
*.pdb
*.sbr
*.tlog
*.user
*.idb
*.htm

\.vs
\__tmp__
*.bak
*res








